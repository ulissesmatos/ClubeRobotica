# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=SUBSTITUA_POR_SEGREDO_FORTE_64_BYTES_HEX
JWT_REFRESH_SECRET=SUBSTITUA_POR_OUTRO_SEGREDO_FORTE_64_BYTES_HEX

# ─── Banco de Dados ───────────────────────────────────────────────────────────
# Em produção (Docker): montar volume em /data
DB_PATH=/data/db.sqlite

# ─── Uploads ─────────────────────────────────────────────────────────────────
# Em produção (Docker): montar volume em /uploads
UPLOAD_DIR=/uploads
MAX_FILE_SIZE_MB=100

# ─── CORS ────────────────────────────────────────────────────────────────────
# Em produção: somente o domínio real do frontend (sem barra no final)
CORS_ORIGIN=https://seudominio.com
# ─── Admin padrão (usado apenas no seed inicial) ─────────────────────────────
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=TrocaPorUmaSenhaMuitoForte!
